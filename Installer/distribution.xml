<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
  <title>Soul FX by Afroplug</title>
  <welcome file="welcome.html" mime-type="text/html"/>
  <license file="license.html" mime-type="text/html"/>
  <options customize="never" require-scripts="false" hostArchitectures="arm64,x86_64"/>
  <choices-outline>
    <line choice="vst3"/>
    <line choice="au"/>
  </choices-outline>
  <choice id="vst3" title="VST3 Plugin"
          description="Installs Soul FX VST3 to /Library/Audio/Plug-Ins/VST3">
    <pkg-ref id="com.afroplug.soulfx.vst3"/>
  </choice>
  <choice id="au" title="Audio Unit Plugin"
          description="Installs Soul FX AU to /Library/Audio/Plug-Ins/Components">
    <pkg-ref id="com.afroplug.soulfx.au"/>
  </choice>
  <pkg-ref id="com.afroplug.soulfx.vst3" version="1.0.0">SoulFX-VST3.pkg</pkg-ref>
  <pkg-ref id="com.afroplug.soulfx.au"   version="1.0.0">SoulFX-AU.pkg</pkg-ref>
</installer-gui-script>
